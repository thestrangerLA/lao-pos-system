    instruction: "Add the Accounting view to the main content area."
    replacement_infos {
      original_chunk {
        target_content: "        </div>\n      </>\n    )}\n  </main>\n"
        replacement_content: "          {activeTab === \'accounting\' && (\n            <div className=\"space-y-8 pb-10\">\n              <div className=\"flex items-center gap-3\">\n                <div className=\"w-10 h-10 rounded-xl bg-emerald-500/10 flex items-center justify-center text-emerald-400\">\n                  <Landmark className=\"w-6 h-6\" />\n                </div>\n                <h2 className=\"text-2xl font-black uppercase tracking-tight\">\340\272\232\340\272\261\340\272\231\340\272\212\340\272\265 \340\273\201\340\272\245\340\272\260 \340\272\201\340\272\262\340\272\231\340\273\200\340\272\207\340\272\264\340\272\231</h2>\n              </div>\n\n              <div className=\"grid grid-cols-1 md:grid-cols-3 gap-6\">\n                <Card className=\"bg-emerald-500/10 border-emerald-500/20\">\n                  <div className=\"text-xs font-bold text-emerald-400/60 mb-2 uppercase\">\340\272\215\340\272\255\340\272\224\340\273\200\340\272\207\340\272\264\340\272\231\340\272\252\340\272\273\340\272\224 (\340\272\233\340\272\260\340\272\241\340\272\262\340\272\231)</div>\n                  <div className=\"text-3xl font-black text-emerald-400\">\n                    <span className=\"text-sm mr-1\">\342\202\255</span>\n                    {kpiStats.revenue.toLocaleString()}\n                  </div>\n                </Card>\n                <Card className=\"bg-amber-500/10 border-amber-500/20\">\n                  <div className=\"text-xs font-bold text-amber-400/60 mb-2 uppercase\">\340\272\225\340\272\273\340\273\211\340\272\231\340\272\227\340\272\266\340\272\231\340\272\252\340\272\264\340\272\231\340\272\204\340\273\211\340\272\262</div>\n                  <div className=\"text-3xl font-black text-amber-400\">\n                    <span className=\"text-sm mr-1\">\342\202\255</span>\n                    {kpiStats.cost.toLocaleString()}\n                  </div>\n                </Card>\n                <Card className=\"bg-indigo-500/10 border-indigo-500/20\">\n                  <div className=\"text-xs font-bold text-indigo-400/60 mb-2 uppercase\">\340\272\201\340\272\263\340\273\204\340\272\245\340\272\252\340\272\260\340\272\252\340\272\273\340\272\241</div>\n                  <div className=\"text-3xl font-black text-indigo-400\">\n                    <span className=\"text-sm mr-1\">\342\202\255</span>\n                    {kpiStats.profit.toLocaleString()}\n                  </div>\n                </Card>\n              </div>\n\n              <div className=\"grid grid-cols-1 lg:grid-cols-2 gap-8\">\n                <Card>\n                  <h3 className=\"text-sm font-bold uppercase tracking-widest text-white/40 mb-6 flex items-center gap-2\">\n                    <TrendingUp className=\"w-4 h-4\" />\n                    \340\272\201\340\272\262\340\272\231\340\273\200\340\272\204\340\272\267\340\273\210\340\272\255\340\272\231\340\273\204\340\272\253\340\272\247\340\272\245\340\272\262\340\272\215\340\273\204\340\272\224\340\273\211\n                  </h3>\n                  <div className=\"h-64\">\n                    <ResponsiveContainer width=\"100%\" height=\"100%\">\n                      <AreaChart data={[...reportData].reverse()}>\n                        <defs>\n                          <linearGradient id=\"colorRev\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n                            <stop offset=\"5%\" stopColor=\"#6366f1\" stopOpacity={0.3}/>\n                            <stop offset=\"95%\" stopColor=\"#6366f1\" stopOpacity={0}/>\n                          </linearGradient>\n                        </defs>\n                        <CartesianGrid strokeDasharray=\"3 3\" stroke=\"#ffffff05\" vertical={false} />\n                        <XAxis \n                          dataKey=\"date\" \n                          stroke=\"#ffffff20\" \n                          fontSize={10} \n                          tickFormatter={(val) => val.split(\'-\')[2]}\n                        />\n                        <YAxis stroke=\"#ffffff20\" fontSize={10} />\n                        <Tooltip \n                          contentStyle={{ backgroundColor: \'#161623\', border: \'1px solid rgba(255,255,255,0.1)\', borderRadius: \'12px\' }}\n                          itemStyle={{ color: \'#fff\' }}\n                        />\n                        <Area type=\"monotone\" dataKey=\"revenue\" stroke=\"#6366f1\" fillOpacity={1} fill=\"url(#colorRev)\" />\n                      </AreaChart>\n                    </ResponsiveContainer>\n                  </div>\n                </Card>\n\n                <Card>\n                  <h3 className=\"text-sm font-bold uppercase tracking-widest text-white/40 mb-6 flex items-center gap-2\">\n                    <CreditCard className=\"w-4 h-4\" />\n                    \340\272\247\340\272\264\340\272\227\340\272\265\340\272\201\340\272\262\340\272\231\340\272\212\340\272\263\340\272\245\340\272\260\340\273\200\340\272\207\340\272\264\340\272\231\n                  </h3>\n                  <div className=\"space-y-4\">\n                    <div className=\"flex items-center justify-between p-4 bg-white/5 rounded-xl\">\n                      <div className=\"flex items-center gap-3\">\n                        <div className=\"w-10 h-10 rounded-lg bg-emerald-500/20 flex items-center justify-center text-emerald-400\">\n                          <Banknote className=\"w-5 h-5\" />\n                        </div>\n                        <div>\n                          <div className=\"font-bold\">\340\273\200\340\272\207\340\272\264\340\272\231\340\272\252\340\272\273\340\272\224</div>\n                          <div className=\"text-[10px] text-white/20 uppercase\">Cash Payments</div>\n                        </div>\n                      </div>\n                      <div className=\"text-right\">\n                        <div className=\"font-black text-emerald-400\">{kpiStats.revenue.toLocaleString()} \342\202\255</div>\n                        <div className=\"text-[10px] text-white/20\">100% \340\272\202\340\272\255\340\272\207\340\272\227\340\272\261\340\272\207\340\273\235\340\272\273\340\272\224</div>\n                      </div>\n                    </div>\n                    <div className=\"p-4 bg-white/[0.02] border border-white/5 rounded-xl border-dashed opacity-50 flex items-center justify-center py-6\">\n                      <span className=\"text-xs text-white/20 uppercase font-bold tracking-widest\">\340\272\215\340\272\261\340\272\207\340\272\232\340\273\215\340\273\210\340\272\241\340\272\265\340\272\202\340\273\215\340\273\211\340\272\241\340\272\271\340\272\231\340\272\247\340\272\264\340\272\227\340\272\265\340\272\255\340\272\267\340\273\210\340\272\231</span>\n                    </div>\n                  </div>\n                </Card>\n              </div>\n            </div>\n          )}\n        </div>\n      </>\n    )}\n  </main>\n"
      }
      num_matches: 1
    }
  }
