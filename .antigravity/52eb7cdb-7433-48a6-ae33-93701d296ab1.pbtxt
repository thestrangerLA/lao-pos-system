  planner_response {
    modified_response: "\340\273\204\340\272\224\340\273\211\340\273\200\340\272\236\340\272\265\340\273\210\340\272\241\340\273\201\340\272\226\340\272\232 **\"\340\272\232\340\272\261\340\272\231\340\272\212\340\272\265\" (Accounting)** \340\273\200\340\272\202\340\272\273\340\273\211\340\272\262\340\273\203\340\272\231\340\273\201\340\272\226\340\272\232\340\273\200\340\272\241\340\272\231\340\272\271\340\272\253\340\272\274\340\272\261\340\272\201\340\272\225\340\272\262\340\272\241\340\272\227\340\272\265\340\273\210\340\272\227\340\273\210\340\272\262\340\272\231\340\272\225\340\273\211\340\272\255\340\272\207\340\272\201\340\272\262\340\272\231\340\273\201\340\272\245\340\273\211\340\272\247.\n\n### \340\272\252\340\272\264\340\273\210\340\272\207\340\272\227\340\272\265\340\273\210\340\273\204\340\272\224\340\273\211\340\272\233\340\273\210\340\272\275\340\272\231\340\273\201\340\272\233\340\272\207:\n1.  **\340\273\200\340\272\236\340\272\265\340\273\210\340\272\241\340\272\233\340\272\270\340\273\210\340\272\241 \"\340\272\232\340\272\261\340\272\231\340\272\212\340\272\265\"**: \340\273\203\340\272\231\340\273\201\340\272\226\340\272\232\340\273\200\340\272\241\340\272\231\340\272\271\340\272\224\340\273\211\340\272\262\340\272\231\340\273\200\340\272\227\340\272\264\340\272\207 (Tab Bar) \340\273\202\340\272\224\340\272\215\340\273\203\340\272\212\340\273\211\340\273\204\340\272\255\340\272\204\340\272\255\340\272\231 `Landmark`.\n2.  **\340\272\252\340\273\211\340\272\262\340\272\207\340\273\234\340\273\211\340\272\262\340\272\252\340\272\260\340\272\253\340\272\274\340\272\270\340\272\232\340\272\232\340\272\261\340\272\231\340\272\212\340\272\265**: \340\273\200\340\272\241\340\272\267\340\273\210\340\272\255\340\272\204\340\272\245\340\272\264\340\272\201\340\273\200\340\272\202\340\272\273\340\273\211\340\272\262\340\273\204\340\272\233\340\272\227\340\272\265\340\273\210\340\273\201\340\272\226\340\272\232 \"\340\272\232\340\272\261\340\272\231\340\272\212\340\272\265\", \340\272\227\340\273\210\340\272\262\340\272\231\340\272\210\340\272\260\340\273\200\340\272\253\340\272\261\340\272\231:\n    *   **\340\272\252\340\272\260\340\272\253\340\272\274\340\272\270\340\272\232\340\272\225\340\272\273\340\272\247\340\273\200\340\272\245\340\272\201**: \340\272\215\340\272\255\340\272\224\340\273\200\340\272\207\340\272\264\340\272\231\340\272\252\340\272\273\340\272\224\340\272\227\340\272\261\340\272\207\340\273\235\340\272\273\340\272\224, \340\272\225\340\272\273\340\273\211\340\272\231\340\272\227\340\272\266\340\272\231\340\272\252\340\272\264\340\272\231\340\272\204\340\273\211\340\272\262, \340\273\201\340\272\245\340\272\260 \340\272\201\340\272\263\340\273\204\340\272\245\340\272\252\340\272\260\340\272\252\340\272\273\340\272\241.\n    *   **\340\272\201\340\272\243\340\272\262\340\272\237\340\272\201\340\272\262\340\272\231\340\273\200\340\272\204\340\272\267\340\273\210\340\272\255\340\272\231\340\273\204\340\272\253\340\272\247\340\272\245\340\272\262\340\272\215\340\273\204\340\272\224\340\273\211**: \340\272\252\340\272\260\340\273\201\340\272\224\340\272\207\340\272\227\340\273\210\340\272\262\340\272\255\340\273\210\340\272\275\340\272\207\340\272\202\340\272\255\340\272\207\340\272\245\340\272\262\340\272\215\340\273\204\340\272\224\340\273\211\340\273\203\340\272\231\340\273\201\340\272\225\340\273\210\340\272\245\340\272\260\340\272\247\340\272\261\340\272\231.\n    *   **\340\272\201\340\272\262\340\272\231\340\273\201\340\272\232\340\273\210\340\272\207\340\272\233\340\272\260\340\273\200\340\272\236\340\272\224\340\272\201\340\272\262\340\272\231\340\272\212\340\272\263\340\272\245\340\272\260**: \340\272\252\340\272\260\340\273\201\340\272\224\340\272\207\340\272\245\340\272\262\340\272\215\340\272\245\340\272\260\340\272\255\340\272\275\340\272\224\340\272\201\340\272\262\340\272\231\340\272\212\340\272\263\340\272\245\340\272\260\340\273\200\340\272\207\340\272\264\340\272\231 (\340\273\2