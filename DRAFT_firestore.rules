rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Products Collection ---
    match /products/{productId} {
      function isValidProduct(data) {
        return data.keys().hasAll(['name', 'price', 'cost', 'category', 'stock']) &&
               data.name is string && data.name.size() <= 200 &&
               data.price is number && data.price >= 0 &&
               data.cost is number && data.cost >= 0 &&
               data.category is string && data.category.size() <= 50 &&
               data.stock is number &&
               (!('costTHB' in data) || (data.costTHB is number && data.costTHB >= 0)) &&
               (!('wholesalePrice' in data) || (data.wholesalePrice is number && data.wholesalePrice >= 0)) &&
               (!('image' in data) || (data.image is string && data.image.size() <= 1000));
      }

      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(productId) && isValidProduct(incoming()) && incoming().keys().size() <= 9;
      allow update: if isSignedIn() && isValidProduct(incoming()) && (
        // Any authenticated user can manage inventory in this basic version
        incoming().diff(existing()).affectedKeys().hasAny(['name', 'price', 'cost', 'costTHB', 'wholesalePrice', 'category', 'stock', 'image'])
      );
      allow delete: if isSignedIn();
    }

    // --- Sales Collection ---
    match /sales/{saleId} {
      function isValidSale(data) {
        return data.keys().hasAll(['id', 'timestamp', 'items', 'subtotal', 'tax', 'discount', 'total', 'paymentMethod']) &&
               data.id is string && data.id.size() <= 100 &&
               data.timestamp is number &&
               data.items is list && data.items.size() > 0 &&
               data.subtotal is number && data.subtotal >= 0 &&
               data.tax is number && data.tax >= 0 &&
               data.discount is number && data.discount >= 0 &&
               data.total is number && data.total >= 0 &&
               data.total == (data.subtotal - data.discount) &&
               data.paymentMethod in ['cash', 'card', 'qr'];
      }

      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(saleId) && isValidSale(incoming()) && incoming().keys().size() == 8;
      allow update, delete: if false; // Sales are immutable records
    }
  }
}
